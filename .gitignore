# Build output
[Bb]in/
[Oo]bj/
*.dll
*.pdb
*.exe
*.cache
.vs/
*.user

# Datasets: the large dataset BLOBS live on GOOGLE DRIVE (link in data/DATA_ACCESS.md), NOT in git
# (6.3 GB total - geocrack 4.9 GB etc.; too big for GitHub's 1 GB free LFS). The data/ FOLDER, its
# structure, and ALL metadata/docs are KEPT and tracked so the folder + provenance are never lost.
# The actual blobs also live locally at D:/code_ws/Data/ (outside this repo, so git never touches them).
/data/**
!/data/**/
!/data/**/*.md
!/data/**/*.txt
!/data/**/*.csv
!/data/**/*.json
!/data/**/*.3dm
# Loviisa fracture-map shapefiles are SMALL (~2 MB) and the in-git exception (LFS); the big blobs stay on Drive.
!/data/loviisa/**/*.shp
!/data/loviisa/**/*.shx
!/data/loviisa/**/*.dbf
!/data/loviisa/**/*.prj
!/data/loviisa/**/*.cpg

# install/ ships the deployable plugin binaries (overrides the global *.dll / *.exe ignores above).
# Large ones (.dll/.exe/.gha/.bin) are stored via Git LFS (see .gitattributes).
!install/plugin/*.dll
!install/plugin/*.exe
!install/plugin/*.gha
!install/tools/*.exe
!install/tools/*.dll
!install/tools/*.txt

# Rhino/GH temp
*.3dmbak
*.rhl
*_backup*

# OS / editor
Thumbs.db
.DS_Store

install/yak_build/
*.yak
.mcp.json
