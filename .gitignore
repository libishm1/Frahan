# Build output
[Bb]in/
[Oo]bj/
*.dll
*.pdb
*.exe
*.cache
.vs/
*.user

# Large dataset blobs: tracked via Git LFS at the public step, not in normal git.
# Only the attribution markdown + README + small .3dm fixtures are committed now.
/data/**
!/data/**/
!/data/**/*.md
!/data/**/*.3dm

# install/ ships the deployable plugin binaries (overrides the global *.dll / *.exe ignores above).
# Large ones (.dll/.exe/.gha/.bin) are stored via Git LFS (see .gitattributes).
!install/plugin/*.dll
!install/plugin/*.exe
!install/plugin/*.gha
!install/tools/*.exe

# Rhino/GH temp
*.3dmbak
*.rhl
*_backup*

# OS / editor
Thumbs.db
.DS_Store
