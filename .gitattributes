# Git LFS - large deployable binaries shipped in install/ (and any bundled weights/native libs)
install/weights/*.bin   filter=lfs diff=lfs merge=lfs -text
install/plugin/*.dll     filter=lfs diff=lfs merge=lfs -text
install/plugin/*.gha     filter=lfs diff=lfs merge=lfs -text
install/plugin/*.exe     filter=lfs diff=lfs merge=lfs -text
install/tools/*.exe      filter=lfs diff=lfs merge=lfs -text
# BFF (Boundary First Flattening) runtime dependencies: SuiteSparse + BLAS/LAPACK
# + MinGW runtime DLLs that ship beside bff-command-line.exe (~66 MB).
install/tools/*.dll      filter=lfs diff=lfs merge=lfs -text
# GPR radargram binaries bundled with example cards (multi-MB raw traces).
examples/**/*.rd3        filter=lfs diff=lfs merge=lfs -text
examples/**/*.rd7        filter=lfs diff=lfs merge=lfs -text
# Kintsugi parity samples are small; keep them as normal git blobs (no LFS)
examples/**/*.laz        filter=lfs diff=lfs merge=lfs -text
examples/**/*.las        filter=lfs diff=lfs merge=lfs -text

# Shapefile binaries (ESRI .shp/.dbf/.shx) - keep the repo clean
examples/**/*.shp filter=lfs diff=lfs merge=lfs -text
examples/**/*.dbf filter=lfs diff=lfs merge=lfs -text
examples/**/*.shx filter=lfs diff=lfs merge=lfs -text
data/**/*.shp filter=lfs diff=lfs merge=lfs -text
data/**/*.dbf filter=lfs diff=lfs merge=lfs -text
data/**/*.shx filter=lfs diff=lfs merge=lfs -text
