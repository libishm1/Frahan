<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <!-- net48 host. RhinoCommon 8 is built for .NET Framework 4.8. -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
  <runtime>
    <!--
      Rhino.Inside 7.0.0 is the only locally-cached resolver and predates
      Rhino 8's RhinoCore startup, which expects its satellite managed
      assemblies (RhinoWindows / Rhino.UI / Eto) next to the executing
      assembly. Rather than copy ~hundreds of MB of Rhino DLLs into the
      harness bin folder, redirect the default-context Assembly.Load for each
      satellite to the Rhino 8 System dir via <codeBase>. codeBase is the
      standard .NET Framework Fusion mechanism for binding a strong-named
      assembly to an explicit location; all four assemblies share
      publicKeyToken 552281e97c755530.

      If a future restore brings in a Rhino-8-matched Rhino.Inside (8.x/9.x),
      its resolver handles this and these redirects become inert.
    -->
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="RhinoWindows" publicKeyToken="552281e97c755530" culture="neutral" />
        <codeBase version="8.30.26103.11001" href="file:///C:/Program Files/Rhino 8/System/RhinoWindows.dll" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Rhino.UI" publicKeyToken="552281e97c755530" culture="neutral" />
        <codeBase version="8.30.26103.11001" href="file:///C:/Program Files/Rhino 8/System/Rhino.UI.dll" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="Eto" publicKeyToken="552281e97c755530" culture="neutral" />
        <codeBase version="2.11.0.0" href="file:///C:/Program Files/Rhino 8/System/Eto.dll" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>
